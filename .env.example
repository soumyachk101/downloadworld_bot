BOT_TOKEN=telegram_bot_token_here
GROQ_API_KEY=groq_api_key_here

# Optional: Instagram credentials for downloading private posts
# Uncomment and fill if you need to download private Instagram posts
# INSTA_USERNAME=your_instagram_username
# INSTA_PASSWORD=your_instagram_password

# Optional: YouTube cookies file to avoid bot detection
# Download using browser extension: https://github.com/yt-dlp/yt-dlp/wiki/Extractors#exporting-youtube-cookies
# YOUTUBE_COOKIES_FILE=youtube_cookies.txt

# Alternative: YouTube extractor args (bypass without cookies)
# Extract visitor_data from browser's YouTube localStorage:
# 1. Open DevTools (F12) on youtube.com
# 2. Console: copy(JSON.parse(localStorage.getItem('youtube-visitor-data')))
# 3. Use the 'visitorData' value
# Format: "youtube:player_skip=webpage,configs;visitor_data=VISITOR_DATA"
# YOUTUBE_EXTRACTOR_ARGS="youtube:player_skip=webpage,configs;visitor_data=YOUR_VISITOR_DATA"
